{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "reason", "feedbackReferences"],
  "properties": {
    "status": { "enum": ["SPEC_READY", "NEEDS_EVIDENCE"] },
    "reason": { "type": "string", "minLength": 1 },
    "feedbackReferences": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "missingEvidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "contract": {
      "$ref": "https://signalpatch.dev/schemas/issue-contract.schema.json"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "SPEC_READY" } } },
      "then": { "required": ["contract"] }
    },
    {
      "if": { "properties": { "status": { "const": "NEEDS_EVIDENCE" } } },
      "then": { "required": ["missingEvidence"] }
    }
  ]
}
