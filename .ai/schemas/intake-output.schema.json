{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["result"],
  "properties": {
    "result": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason", "feedbackReferences", "contract"],
          "properties": {
            "status": { "type": "string", "const": "SPEC_READY" },
            "reason": { "type": "string", "minLength": 1 },
            "feedbackReferences": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "contract": {
              "$ref": "https://signalpatch.dev/schemas/issue-contract.schema.json"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason",
            "feedbackReferences",
            "missingEvidence"
          ],
          "properties": {
            "status": { "type": "string", "const": "NEEDS_EVIDENCE" },
            "reason": { "type": "string", "minLength": 1 },
            "feedbackReferences": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "missingEvidence": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    }
  }
}
