{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signalpatch.dev/schemas/issue-contract.schema.json",
  "title": "SignalPatch Issue Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "source",
    "problemSummary",
    "actualBehavior",
    "expectedBehavior",
    "evidence",
    "reproductionSteps",
    "acceptanceCriteria",
    "nonGoals",
    "allowedPaths",
    "riskLevel",
    "runtimeAcceptance",
    "privacy"
  ],
  "properties": {
    "status": { "type": "string", "const": "SPEC_READY" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "references"],
      "properties": {
        "kind": { "enum": ["feedback", "codex-conversation", "manual-issue"] },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "problemSummary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "actualBehavior": { "type": "string", "minLength": 1 },
    "expectedBehavior": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value", "redacted"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "redacted": { "type": "boolean" }
        }
      }
    },
    "reproductionSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "validator"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
          "statement": { "type": "string", "minLength": 1 },
          "validator": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nonGoals": { "type": "array", "items": { "type": "string" } },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(\\.|\\.{3,}|[A-Za-z0-9._\\[\\]-]*[A-Za-z0-9_\\[\\]-][A-Za-z0-9._\\[\\]-]*)(/(\\.|\\.{3,}|[A-Za-z0-9._\\[\\]-]*[A-Za-z0-9_\\[\\]-][A-Za-z0-9._\\[\\]-]*))*$"
      }
    },
    "riskLevel": { "enum": ["R0", "R1", "R2", "R3"] },
    "runtimeAcceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawConversationIncluded", "redactionSummary"],
      "properties": {
        "rawConversationIncluded": { "type": "boolean", "const": false },
        "redactionSummary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
