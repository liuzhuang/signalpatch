{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "GitHub Actions Workflow 结构",
    "subtitle": "on → permissions → jobs → steps → outputs（中文释义）",
    "output": "github-actions-structure.html",
    "viewBox": [720, 820]
  },
  "lanes": [
    { "id": "flow", "label": "执行与声明顺序" },
    { "id": "data", "label": "输出与跨 Job 传参" }
  ],
  "phases": [
    { "id": "trigger", "label": "① on", "fromCol": 0, "toCol": 2 },
    { "id": "authz", "label": "② 权限", "fromCol": 4, "toCol": 4 },
    { "id": "exec", "label": "③ jobs / steps", "fromCol": 5, "toCol": 5 }
  ],
  "mainPath": ["event", "on", "permissions", "job"],
  "nodes": [
    {
      "id": "event",
      "lane": "flow",
      "col": 0,
      "type": "external",
      "label": "外部事件",
      "sublabel": "cron / dispatch…",
      "width": 80
    },
    {
      "id": "on",
      "lane": "flow",
      "col": 2,
      "type": "frontend",
      "label": "on",
      "sublabel": "触发器",
      "width": 80
    },
    {
      "id": "permissions",
      "lane": "flow",
      "col": 4,
      "type": "security",
      "label": "permissions",
      "sublabel": "令牌权限",
      "width": 80
    },
    {
      "id": "job",
      "lane": "flow",
      "col": 5,
      "type": "backend",
      "label": "Job + steps",
      "sublabel": "jobs 内：逐步执行",
      "width": 80
    },
    {
      "id": "step_out",
      "lane": "data",
      "col": 5,
      "type": "database",
      "label": "步骤输出",
      "sublabel": "steps.*.outputs",
      "width": 80
    },
    {
      "id": "job_out",
      "lane": "data",
      "col": 4,
      "type": "database",
      "label": "Job 输出",
      "sublabel": "jobs.*.outputs",
      "width": 80
    },
    {
      "id": "next_job",
      "lane": "data",
      "col": 2,
      "type": "backend",
      "label": "下一 Job",
      "sublabel": "needs + if",
      "width": 80
    }
  ],
  "edges": [
    { "from": "event", "to": "on", "variant": "emphasis" },
    { "from": "on", "to": "permissions", "variant": "default" },
    { "from": "permissions", "to": "job", "variant": "emphasis" },
    {
      "from": "job",
      "to": "step_out",
      "variant": "dashed",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    },
    {
      "from": "step_out",
      "to": "job_out",
      "variant": "dashed",
      "fromSide": "left",
      "toSide": "right"
    },
    {
      "from": "job_out",
      "to": "next_job",
      "variant": "emphasis",
      "fromSide": "bottom",
      "toSide": "top",
      "route": "drop"
    }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "on 触发器",
      "items": [
        "声明 Workflow 在什么事件下运行",
        "例：schedule cron、workflow_dispatch 手动",
        "例：pull_request、issues.opened、workflow_run"
      ]
    },
    {
      "dot": "rose",
      "title": "permissions 权限",
      "items": [
        "限制 GITHUB_TOKEN 可读/可写范围",
        "Workflow 级默认；单个 Job 可收紧或放宽",
        "例：顶层 contents: read；publish Job 另开 issues: write"
      ]
    },
    {
      "dot": "emerald",
      "title": "jobs 与 steps",
      "items": [
        "jobs：具名 Job；needs 决定等待哪些上游 Job",
        "steps：同一 Job 内顺序执行；uses 或 run",
        "if: needs.<job>.outputs.<name> 控制是否运行"
      ]
    },
    {
      "dot": "amber",
      "title": "outputs 产出",
      "items": [
        "步骤：echo \"k=v\" >> $GITHUB_OUTPUT",
        "Job：outputs 块映射 steps.<id>.outputs",
        "跨 Job 文件：upload-artifact / download-artifact"
      ]
    },
    {
      "dot": "cyan",
      "title": "feedback-intake 对照",
      "items": [
        "collect → qualify → publish 三个 Job",
        "collect.outputs.has_feedback 供 qualify 的 if",
        "scan 步骤 id 供 outputs 引用"
      ]
    }
  ]
}
